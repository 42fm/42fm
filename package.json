{
  "name": "42fm",
  "version": "0.1.8",
  "scripts": {
    "build": "yarn build:chromium:prod && yarn build:firefox:prod",
    "start:chromium": "webpack --env=DIST=chromium --env=BROWSER=chrome --watch --config webpack.dev.js",
    "start:firefox": "webpack --env=DIST=firefox --env=BROWSER=firefox --watch --config webpack.dev.js",
    "build:chromium:prod": "webpack --mode production --env=DIST=chromium --env=BROWSER=chrome --config webpack.prod.js",
    "build:firefox:prod": "webpack --mode production --env=DIST=firefox --env=BROWSER=firefox --config webpack.prod.js",
    "build:chromium:dev": "webpack --env=DIST=chromium --env=BROWSER=chrome --config webpack.dev.js",
    "build:firefox:dev": "webpack --env=DIST=firefox --env=BROWSER=firefox --config webpack.dev.js",
    "package": "(cd dist/chromium && zip -r ../42fm_chromium_$(jq -r .version ../../package.json).zip . *) && (cd dist/firefox && zip -r ../42fm_firefox_$(jq -r .version ../../package.json).zip . *)",
    "zip-source": "git ls-files --recurse-submodules | tar caf ./source.tar.gz -T-"
  },
  "author": "loczek",
  "license": "MIT",
  "dependencies": {
    "@floating-ui/react": "^0.27.18",
    "@iconscout/react-unicons": "^2.2.5",
    "@js-temporal/polyfill": "^0.5.1",
    "clean-webpack-plugin": "^4.0.0",
    "date-fns": "^4.1.0",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.6",
    "jwt-decode": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-loader": "^4.13.1",
    "react-merge-refs": "^3.0.2",
    "socket.io-client": "^4.8.3",
    "styled-components": "^6.3.11",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@hot-loader/react-dom": "^17.0.2",
    "@swc/core": "^1.15.18",
    "@types/chrome": "^0.1.37",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/webextension-polyfill": "^0.12.5",
    "@types/youtube": "^0.1.2",
    "@vitejs/plugin-react": "^5.1.4",
    "copy-webpack-plugin": "^13.0.1",
    "dotenv": "^17.3.1",
    "dotenv-webpack": "^8.1.1",
    "semver": "^7.7.4",
    "swc-loader": "^0.2.7",
    "terser-webpack-plugin": "^5.3.16",
    "typescript": "^5.9.3",
    "val-loader": "^6.0.0",
    "vite-plugin-static-copy": "^3.2.0",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^6.0.1"
  },
  "packageManager": "yarn@4.1.1"
}
